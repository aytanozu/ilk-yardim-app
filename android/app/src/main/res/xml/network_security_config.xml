<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext HTTP to the Firebase Emulator suite only. The
  Android emulator maps its own host machine's loopback to 10.0.2.2;
  127.0.0.1/localhost cover direct-desktop builds. Everything else
  still defaults to HTTPS-only, so this config is safe to ship in
  release builds (production never talks to 10.0.2.2).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
