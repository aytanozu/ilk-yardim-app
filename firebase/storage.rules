rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function isCertified() {
      return isSignedIn() && request.auth.token.certified == true;
    }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Post images — author only
    match /posts/{uid}/{file} {
      allow read: if isCertified();
      allow write: if isSelf(uid) && isCertified()
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Avatars
    match /avatars/{uid}/{file} {
      allow read: if true;
      allow write: if isSelf(uid)
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Training videos — admin (server) only
    match /training/{file} {
      allow read: if isCertified();
      allow write: if false;
    }

    // Registration certificate uploads — any signed-in user can upload
    // their OWN directory; dispatchers (via server claims) can read
    // during approval. No delete from client.
    match /registration_docs/{uid}/{file} {
      allow read: if isSelf(uid)
                  || (isSignedIn() && request.auth.token.role == 'dispatcher');
      allow create: if isSelf(uid)
                    && request.resource.size < 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow update, delete: if isSignedIn()
                            && request.auth.token.role == 'dispatcher';
    }
  }
}
