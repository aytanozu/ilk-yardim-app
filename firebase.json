{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "ilk-yardim-3465",
          "appId": "1:3507758073:android:c64cbf7cbe9d71acb69328",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "ilk-yardim-3465",
          "appId": "1:3507758073:ios:4858c614fdd8241ab69328",
          "uploadDebugSymbols": true,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "ilk-yardim-3465",
          "configurations": {
            "android": "1:3507758073:android:c64cbf7cbe9d71acb69328",
            "ios": "1:3507758073:ios:4858c614fdd8241ab69328"
          }
        }
      }
    }
  },
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "functions": [
    {
      "source": "firebase/functions",
      "codebase": "default",
      "runtime": "nodejs20",
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ],
  "hosting": {
    "public": "admin_panel/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "emulators": {
    "auth": { "port": 9099 },
    "firestore": { "port": 8080 },
    "functions": { "port": 5001 },
    "storage": { "port": 9199 },
    "hosting": { "port": 5000 },
    "ui": { "enabled": true }
  }
}
