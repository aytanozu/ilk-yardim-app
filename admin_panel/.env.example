VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=

# Set to "true" to route the admin panel at Firebase emulators
# running on 127.0.0.1 (Firestore 8080 / Auth 9099 / Functions 5001).
# When enabled, VITE_FB_API_KEY etc. still must be non-empty but can be
# dummy values — the emulator ignores them.
VITE_USE_EMULATOR=false
